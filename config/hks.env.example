# Legacy env-style config. Prefer config/hks.yaml for normal use.
# Copy this file to config/hks.env only when shell-style overrides are needed.
# Keep the real file out of git.

# Required only when using HKS_EMBEDDING_MODEL=openai:<model>.
export HKS_OPENAI_API_KEY="sk-REPLACE_ME"

# OpenAI embedding backend.
export HKS_EMBEDDING_MODEL=openai:text-embedding-3-small

# Optional: use a compatible embeddings endpoint.
# export HKS_OPENAI_EMBEDDING_ENDPOINT="https://api.openai.com/v1/embeddings"

# Optional: supported by text-embedding-3 models.
# export HKS_OPENAI_EMBEDDING_DIMENSIONS=1536

# Optional: request timeout in seconds.
# export HKS_OPENAI_TIMEOUT_SECONDS=60
