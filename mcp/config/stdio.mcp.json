{
  "mcpServers": {
    "hks": {
      "command": "uv",
      "args": [
        "run",
        "hks-mcp",
        "--transport",
        "stdio"
      ],
      "cwd": ".",
      "env": {
        "KS_ROOT": ".hks-runs/work/ks",
        "HKS_WORKSPACE_REGISTRY": ".hks-runs/workspaces.json"
      }
    }
  }
}
