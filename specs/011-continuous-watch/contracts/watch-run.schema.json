{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hks.local/schemas/watch-run.schema.json",
  "title": "HKS Watch run artifact",
  "type": "object",
  "required": ["schema_version", "run_id", "created_at", "completed_at", "status", "plan_id", "plan_fingerprint", "mode", "profile", "requested_by", "actions", "summary"],
  "additionalProperties": false,
  "properties": {
    "schema_version": { "type": "string", "const": "1.0" },
    "run_id": { "type": "string", "minLength": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "completed_at": { "type": ["string", "null"], "format": "date-time" },
    "status": { "type": "string", "enum": ["planned", "running", "completed", "failed", "partial"] },
    "plan_id": { "type": "string", "minLength": 1 },
    "plan_fingerprint": { "type": "string", "minLength": 1 },
    "mode": { "type": "string", "enum": ["dry-run", "execute"] },
    "profile": { "type": "string", "enum": ["scan-only", "ingest-only", "derived-refresh", "wiki-apply", "full"] },
    "requested_by": { "type": ["string", "null"], "minLength": 1 },
    "actions": {
      "type": "array",
      "items": { "$ref": "#/$defs/action" }
    },
    "summary": { "$ref": "#/$defs/summary" }
  },
  "$defs": {
    "action": {
      "type": "object",
      "required": ["action_id", "kind", "source_relpath", "depends_on", "status", "input_fingerprint", "output_refs", "error"],
      "additionalProperties": false,
      "properties": {
        "action_id": { "type": "string", "minLength": 1 },
        "kind": { "type": "string", "enum": ["ingest", "prune", "llm_classify", "wiki_synthesize", "wiki_apply", "graphify_build", "report_issue"] },
        "source_relpath": { "type": ["string", "null"], "minLength": 1 },
        "depends_on": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "status": { "type": "string", "enum": ["planned", "skipped", "running", "completed", "failed"] },
        "input_fingerprint": { "type": ["string", "null"], "minLength": 1 },
        "output_refs": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "error": {
          "type": ["object", "null"],
          "required": ["code", "exit_code", "message"],
          "additionalProperties": false,
          "properties": {
            "code": { "type": "string" },
            "exit_code": { "type": "integer" },
            "message": { "type": "string" }
          }
        }
      }
    },
    "sourceCounts": {
      "type": "object",
      "required": ["unchanged", "stale", "new", "missing", "unsupported", "corrupt"],
      "additionalProperties": false,
      "properties": {
        "unchanged": { "type": "integer", "minimum": 0 },
        "stale": { "type": "integer", "minimum": 0 },
        "new": { "type": "integer", "minimum": 0 },
        "missing": { "type": "integer", "minimum": 0 },
        "unsupported": { "type": "integer", "minimum": 0 },
        "corrupt": { "type": "integer", "minimum": 0 }
      }
    },
    "actionCounts": {
      "type": "object",
      "required": ["planned", "skipped", "running", "completed", "failed"],
      "additionalProperties": false,
      "properties": {
        "planned": { "type": "integer", "minimum": 0 },
        "skipped": { "type": "integer", "minimum": 0 },
        "running": { "type": "integer", "minimum": 0 },
        "completed": { "type": "integer", "minimum": 0 },
        "failed": { "type": "integer", "minimum": 0 }
      }
    },
    "summary": {
      "type": "object",
      "required": ["kind", "operation", "mode", "profile", "plan_id", "run_id", "plan_fingerprint", "source_counts", "action_counts", "artifacts", "idempotent_reuse", "confidence"],
      "additionalProperties": false,
      "properties": {
        "kind": { "type": "string", "const": "watch_summary" },
        "operation": { "type": "string", "enum": ["scan", "run", "status"] },
        "mode": { "type": "string", "enum": ["dry-run", "execute"] },
        "profile": { "type": "string", "enum": ["scan-only", "ingest-only", "derived-refresh", "wiki-apply", "full"] },
        "plan_id": { "type": ["string", "null"], "minLength": 1 },
        "run_id": { "type": ["string", "null"], "minLength": 1 },
        "plan_fingerprint": { "type": ["string", "null"], "minLength": 1 },
        "source_counts": { "$ref": "#/$defs/sourceCounts" },
        "action_counts": { "$ref": "#/$defs/actionCounts" },
        "artifacts": {
          "type": "object",
          "required": ["plan", "run", "latest"],
          "additionalProperties": false,
          "properties": {
            "plan": { "type": ["string", "null"], "minLength": 1 },
            "run": { "type": ["string", "null"], "minLength": 1 },
            "latest": { "type": ["string", "null"], "minLength": 1 }
          }
        },
        "idempotent_reuse": { "type": "boolean" },
        "confidence": { "type": "number", "enum": [0.0, 1.0] }
      }
    }
  }
}
