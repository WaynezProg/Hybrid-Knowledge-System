{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hks.local/schemas/graphify-run.schema.json",
  "title": "HKS Graphify run artifact",
  "type": "object",
  "required": ["run_id", "schema_version", "created_at", "status", "idempotency_key", "input_fingerprint", "algorithm_version", "request", "artifacts"],
  "additionalProperties": false,
  "properties": {
    "run_id": { "type": "string", "minLength": 1 },
    "schema_version": { "type": "integer", "const": 1 },
    "created_at": { "type": "string", "format": "date-time" },
    "status": { "type": "string", "enum": ["valid", "invalid", "partial"] },
    "idempotency_key": { "type": "string", "minLength": 1 },
    "input_fingerprint": { "type": "string", "minLength": 1 },
    "algorithm_version": { "type": "string", "minLength": 1 },
    "request": {
      "type": "object",
      "required": ["mode", "provider_id", "model_id", "include_html", "include_report", "force_new_run"],
      "additionalProperties": false,
      "properties": {
        "mode": { "type": "string", "enum": ["store"] },
        "provider_id": { "type": "string", "minLength": 1 },
        "model_id": { "type": "string", "minLength": 1 },
        "include_html": { "type": "boolean" },
        "include_report": { "type": "boolean" },
        "force_new_run": { "type": "boolean" },
        "requested_by": { "type": ["string", "null"], "minLength": 1 }
      }
    },
    "artifacts": {
      "type": "object",
      "required": ["graph", "communities", "audit", "manifest"],
      "additionalProperties": false,
      "properties": {
        "graph": { "type": "string", "minLength": 1 },
        "communities": { "type": "string", "minLength": 1 },
        "audit": { "type": "string", "minLength": 1 },
        "manifest": { "type": "string", "minLength": 1 },
        "html": { "type": ["string", "null"] },
        "report": { "type": ["string", "null"] }
      }
    }
  }
}
