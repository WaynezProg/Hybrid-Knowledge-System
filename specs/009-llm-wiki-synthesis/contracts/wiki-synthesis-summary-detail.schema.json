{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hks.local/schemas/wiki-synthesis-summary-detail.schema.json",
  "title": "HKS wiki synthesis summary detail",
  "type": "object",
  "required": [
    "operation",
    "mode",
    "candidate",
    "artifact",
    "apply_result",
    "confidence",
    "findings"
  ],
  "additionalProperties": false,
  "properties": {
    "operation": { "type": "string", "const": "wiki_synthesize" },
    "mode": { "type": "string", "enum": ["preview", "store", "apply"] },
    "candidate": { "$ref": "wiki-synthesis-candidate.schema.json" },
    "artifact": {
      "type": ["object", "null"],
      "required": ["artifact_id", "artifact_path", "schema_version", "status"],
      "additionalProperties": false,
      "properties": {
        "artifact_id": { "type": "string", "minLength": 1 },
        "artifact_path": { "type": "string", "minLength": 1 },
        "schema_version": { "type": "integer", "const": 1 },
        "status": { "type": "string", "enum": ["valid", "invalid", "partial"] },
        "idempotent_reuse": { "type": "boolean" }
      }
    },
    "apply_result": {
      "type": ["object", "null"],
      "required": ["operation", "target_slug", "touched_pages", "conflicts", "diff_summary", "idempotent_apply"],
      "additionalProperties": false,
      "properties": {
        "operation": { "type": "string", "enum": ["create", "update", "conflict", "already_applied"] },
        "target_slug": { "type": "string", "minLength": 1 },
        "touched_pages": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        },
        "log_entry_id": { "type": ["string", "null"], "minLength": 1 },
        "conflicts": {
          "type": "array",
          "items": { "$ref": "#/$defs/finding" }
        },
        "diff_summary": { "type": "string", "minLength": 1 },
        "idempotent_apply": { "type": "boolean" }
      }
    },
    "confidence": { "$ref": "#/$defs/confidence" },
    "findings": {
      "type": "array",
      "items": { "$ref": "#/$defs/finding" }
    }
  },
  "$defs": {
    "confidence": {
      "type": "number",
      "minimum": 0.0,
      "maximum": 1.0
    },
    "finding": {
      "type": "object",
      "required": ["severity", "code", "message"],
      "additionalProperties": false,
      "properties": {
        "severity": { "type": "string", "enum": ["error", "warning", "info"] },
        "code": { "type": "string", "minLength": 1 },
        "message": { "type": "string", "minLength": 1 }
      }
    }
  }
}
