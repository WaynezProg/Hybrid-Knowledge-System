{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://hks.local/schemas/mcp-tools.schema.json",
  "title": "HKS MCP tool input schemas",
  "type": "object",
  "required": ["tools"],
  "additionalProperties": false,
  "properties": {
    "tools": {
      "type": "object",
      "required": [
        "hks_query",
        "hks_ingest",
        "hks_lint",
        "hks_pageindex_show",
        "hks_pageindex_enrich"
      ],
      "additionalProperties": false,
      "properties": {
        "hks_query": { "$ref": "#/$defs/hksQueryInput" },
        "hks_ingest": { "$ref": "#/$defs/hksIngestInput" },
        "hks_lint": { "$ref": "#/$defs/hksLintInput" },
        "hks_pageindex_show": { "$ref": "#/$defs/hksPageIndexShowInput" },
        "hks_pageindex_enrich": { "$ref": "#/$defs/hksPageIndexEnrichInput" }
      }
    }
  },
  "$defs": {
    "ksRoot": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "hksQueryInput": {
      "type": "object",
      "required": ["question"],
      "additionalProperties": false,
      "properties": {
        "question": { "type": "string", "minLength": 1 },
        "writeback": {
          "type": "string",
          "enum": ["no", "auto", "yes", "ask"],
          "default": "no"
        },
        "ks_root": { "$ref": "#/$defs/ksRoot" }
      }
    },
    "hksIngestInput": {
      "type": "object",
      "required": ["path"],
      "additionalProperties": false,
      "properties": {
        "path": { "type": "string", "minLength": 1 },
        "prune": { "type": "boolean", "default": false },
        "pptx_notes": {
          "type": "string",
          "enum": ["include", "exclude"],
          "default": "include"
        },
        "ks_root": { "$ref": "#/$defs/ksRoot" }
      }
    },
    "hksLintInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "strict": { "type": "boolean", "default": false },
        "severity_threshold": {
          "type": "string",
          "enum": ["error", "warning", "info"],
          "default": "error"
        },
        "fix": {
          "type": "string",
          "enum": ["none", "plan", "apply"],
          "default": "none"
        },
        "ks_root": { "$ref": "#/$defs/ksRoot" }
      }
    },
    "hksPageIndexShowInput": {
      "type": "object",
      "required": ["source_relpath"],
      "additionalProperties": false,
      "properties": {
        "source_relpath": { "type": "string", "minLength": 1 },
        "ks_root": { "$ref": "#/$defs/ksRoot" }
      }
    },
    "hksPageIndexEnrichInput": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "source_relpath": { "type": ["string", "null"], "minLength": 1 },
        "mode": {
          "type": "string",
          "enum": ["preview", "store"],
          "default": "preview"
        },
        "provider": {
          "type": "string",
          "enum": ["fake", "openai"],
          "default": "fake"
        },
        "model": { "type": ["string", "null"], "minLength": 1 },
        "force": { "type": "boolean", "default": false },
        "ks_root": { "$ref": "#/$defs/ksRoot" }
      }
    }
  }
}
